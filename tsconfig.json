{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    "rootDirs": ["src", "tests"],
    "outDir": "./dist",
    "types": ["node", "vitest/globals"],

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "isolatedModules": true,

    "sourceMap": true
  },
  "include": ["src", "tests"]
}